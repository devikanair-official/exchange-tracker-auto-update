# ── CrewAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Jira ─────────────────────────────────────────────
JIRA_SERVER=https://your-company.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Microsoft Graph (SharePoint/OneDrive upload) ──────
MS_GRAPH_TOKEN=your_microsoft_graph_bearer_token_here
SHAREPOINT_SITE_ID=your_sharepoint_site_id_here
SHAREPOINT_DRIVE_ID=your_sharepoint_drive_id_here
SHAREPOINT_FILE_PATH=/ExchangeTracker/Exchange_Migration_Tracker.xlsx

# ── Tracker ───────────────────────────────────────────
TRACKER_PATH=data/Exchange_Migration_Tracker.xlsx
JIRA_PROJECT_KEY=MIGR
